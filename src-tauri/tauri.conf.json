{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VantagFleet",
  "version": "0.1.0",
  "identifier": "com.vantagfleet.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "VantagFleet Desktop",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://vantagfleet.com/api/update/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVENjM3OEM5MkYxODBCQTAKUldTZ0N4Z3Z5WGhqN2FjZExHRVk3bFBNUGFKU2o1RjRIVGgvSHY1OGxzNHJ4USsyWUJCRWFHUDYK"
    }
  }
}
